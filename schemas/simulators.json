{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "simulators.toml",
  "description": "Simulator adapter definitions for simctl",
  "type": "object",
  "required": ["simulators"],
  "properties": {
    "simulators": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["adapter"],
        "properties": {
          "adapter": {
            "type": "string",
            "description": "Adapter name (e.g. emses, beach, generic)"
          },
          "resolver_mode": {
            "type": "string",
            "enum": ["local_executable", "local_source", "package"],
            "description": "How to resolve the simulator executable"
          },
          "executable": {
            "type": "string",
            "description": "Executable path or name"
          },
          "source_repo": {
            "type": "string",
            "description": "Source repository path (for local_source mode)"
          },
          "build_command": {
            "type": "string",
            "description": "Build command (for local_source mode)"
          },
          "modules": {
            "type": "array",
            "items": { "type": "string" },
            "description": "HPC module names to load"
          }
        }
      }
    }
  }
}
