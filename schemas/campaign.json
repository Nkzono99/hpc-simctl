{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "campaign.toml",
  "description": "Research campaign definition for hpc-simctl",
  "type": "object",
  "properties": {
    "campaign": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Campaign name"
        },
        "description": {
          "type": "string",
          "description": "Research motivation and context"
        },
        "hypothesis": {
          "type": "string",
          "description": "Scientific hypothesis being tested"
        },
        "simulator": {
          "type": "string",
          "description": "Primary simulator for this campaign"
        }
      },
      "required": ["name"]
    },
    "variables": {
      "type": "object",
      "description": "Parameter definitions with roles and ranges",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": ["independent", "dependent", "fixed", "controlled"],
                "description": "Variable role in the experiment"
              },
              "range": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2,
                "description": "[min, max] for independent variables"
              },
              "values": {
                "type": "array",
                "description": "Explicit list of values"
              },
              "unit": {
                "type": "string",
                "description": "Physical unit"
              },
              "reason": {
                "type": "string",
                "description": "Why this variable is set this way"
              }
            },
            "required": ["role"]
          },
          {
            "type": ["number", "string", "boolean", "integer"],
            "description": "Simple fixed value (scalar)"
          },
          {
            "type": "array",
            "description": "Simple fixed value (list)"
          }
        ]
      }
    },
    "observables": {
      "type": "object",
      "description": "Output quantities to measure",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "source": {
                "type": "string",
                "description": "Path or glob to output file"
              },
              "column": {
                "description": "Column index or name"
              },
              "description": {
                "type": "string"
              },
              "unit": {
                "type": "string"
              }
            }
          },
          {
            "type": "string",
            "description": "Simple source path"
          }
        ]
      }
    }
  }
}
