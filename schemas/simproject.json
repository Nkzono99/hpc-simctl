{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "simproject.toml",
  "description": "simctl project configuration",
  "type": "object",
  "required": ["project"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name"
        },
        "description": {
          "type": "string",
          "description": "Project description"
        }
      }
    }
  }
}
