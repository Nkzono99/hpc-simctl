{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "simproject.toml",
  "description": "simctl project configuration",
  "type": "object",
  "required": ["project"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name"
        },
        "description": {
          "type": "string",
          "description": "Project description"
        }
      }
    },
    "knowledge": {
      "type": "object",
      "description": "Knowledge integration configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether knowledge integration is active"
        },
        "mount_dir": {
          "type": "string",
          "default": "refs/knowledge",
          "description": "Base directory for mounting knowledge sources"
        },
        "derived_dir": {
          "type": "string",
          "default": ".simctl/knowledge",
          "description": "Directory for generated/derived knowledge files"
        },
        "auto_sync_on_setup": {
          "type": "boolean",
          "default": true,
          "description": "Sync knowledge sources during simctl setup"
        },
        "generate_claude_imports": {
          "type": "boolean",
          "default": true,
          "description": "Generate CLAUDE.md import stubs for enabled profiles"
        },
        "sources": {
          "type": "array",
          "description": "External knowledge sources",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Source identifier"
              },
              "type": {
                "type": "string",
                "enum": ["git", "path"],
                "description": "Source type"
              },
              "kind": {
                "type": "string",
                "enum": ["profiles", "project", "insights"],
                "description": "Source content kind"
              },
              "url": {
                "type": "string",
                "description": "Git URL for git-type sources"
              },
              "path": {
                "type": "string",
                "description": "Filesystem path for path-type sources"
              },
              "ref": {
                "type": "string",
                "default": "main",
                "description": "Git ref to checkout"
              },
              "mount": {
                "type": "string",
                "description": "Relative mount path from project root"
              },
              "profiles": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Enabled profile names from this source"
              }
            }
          }
        }
      }
    }
  }
}
