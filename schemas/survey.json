{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "survey.toml",
  "description": "Parameter survey definition for simctl (Cartesian product and co-varying expansion). See SPEC section 11 and docs/toml-reference.md.",
  "type": "object",
  "required": ["survey"],
  "properties": {
    "survey": {
      "type": "object",
      "required": ["base_case", "simulator"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Survey identifier (e.g. 'S20260327-cavity-u-a')"
        },
        "name": {
          "type": "string",
          "description": "Human-readable survey name"
        },
        "base_case": {
          "type": "string",
          "description": "Name of the base case to derive runs from (must match a cases/<name>/case.toml)"
        },
        "simulator": {
          "type": "string",
          "description": "Simulator name (must match simulators.toml)"
        },
        "launcher": {
          "type": "string",
          "description": "Launcher profile name (must match launchers.toml)"
        }
      }
    },
    "classification": {
      "type": "object",
      "description": "Optional metadata for organizing runs",
      "properties": {
        "model": {
          "type": "string",
          "description": "Physical model category (e.g. 'sheath', 'wave')"
        },
        "submodel": {
          "type": "string",
          "description": "Subcategory (e.g. 'flat_surface', 'periodic')"
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Free-form tags for filtering"
        }
      }
    },
    "axes": {
      "type": "object",
      "description": "Parameter axes for Cartesian product expansion. Each key is a dot-notation parameter path, value is an array of values to sweep.",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "description": "Array of values for this parameter axis"
      }
    },
    "linked": {
      "type": "array",
      "description": "Co-varying parameter groups. Parameters within each group are zipped (must have equal-length arrays). Multiple groups are combined via Cartesian product with each other and with [axes].",
      "items": {
        "type": "object",
        "additionalProperties": {
          "type": "array",
          "minItems": 1,
          "description": "Array of values for this co-varying parameter"
        }
      }
    },
    "naming": {
      "type": "object",
      "description": "Naming configuration for generated runs",
      "properties": {
        "display_name": {
          "type": "string",
          "description": "Template for run display names. Use {key} placeholders where key is the leaf name after the last dot."
        }
      }
    },
    "job": {
      "type": "object",
      "description": "Slurm job parameters shared across all generated runs",
      "properties": {
        "partition": { "type": "string", "description": "Partition/queue name" },
        "nodes": { "type": "integer", "description": "Number of nodes" },
        "ntasks": { "type": "integer", "description": "Number of MPI tasks" },
        "cpus_per_task": { "type": "integer", "description": "CPUs per task" },
        "walltime": { "type": "string", "description": "Wall time limit (HH:MM:SS)" },
        "job_name": { "type": "string", "description": "Job name prefix" },
        "threads_per_process": { "type": "integer", "description": "Threads per process (for rsc style)" },
        "cores_per_thread": { "type": "integer", "description": "Cores per thread (for rsc style)" }
      }
    }
  }
}
